{
    "manifest_version": 3,
    "name": "Job Tracker",
    "version": "1.0",
    "description": "Instantly save job listings to your Job Tracker board",
    "permissions": [
        "activeTab",
        "scripting",
        "tabs"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Save Job",
        "default_icon": "icon.png"
    },
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    },
    "host_permissions": [
        "<all_urls>"
    ]
}